NODE_ENV=production
PORT=7373
LOG_LEVEL=info
TRUST_PROXY=false
PUBLIC_BASE_URL=https://webhooks.example.com

DATABASE_URL=postgres://webhook:webhook_password@postgres:5432/webhook_gateway
REDIS_URL=redis://redis:6379/0
QUEUE_NAME=webhook-deliveries

ADMIN_TOKEN=replace_with_long_random_admin_token
MAX_BODY_BYTES=1048576
DEFAULT_TOLERANCE_SECONDS=300
DELIVERY_TIMEOUT_MS=30000
QUEUE_ENQUEUE_TIMEOUT_MS=1500

INGRESS_RATE_LIMIT_PER_MINUTE=600
ADMIN_RATE_LIMIT_PER_MINUTE=60
REPLAY_RATE_LIMIT_PER_MINUTE=10
REPLAY_EVENT_COOLDOWN_SECONDS=300
REPLAY_DELIVERY_COOLDOWN_SECONDS=60
REPLAY_MAX_DELIVERIES_PER_REQUEST=100

STORE_RAW_BODY=false
BODY_RETENTION_DAYS=7
REDACT_HEADER_NAMES=authorization,cookie,set-cookie,x-api-key,x-admin-token
ADMIN_ALLOWED_CIDRS=

ENABLE_CLOCK_SKEW_CHECK=true
CLOCK_SKEW_REQUIRED=true
MAX_CLOCK_SKEW_SECONDS=30
CLOCK_SKEW_CACHE_SECONDS=30
CLOCK_SKEW_CHECK_MODE=chronyc

ENABLE_EMERGENCY_SPOOL=true
SPOOL_STORAGE_MODE=encrypted_volume
SPOOL_DIR=/spool
SPOOL_RETENTION_DAYS=7
SPOOL_FAILED_RETENTION_DAYS=7
SPOOL_IMPORT_BATCH_SIZE=50
RECOVERY_INTERVAL_MS=30000
RECOVERY_DELIVERY_BATCH_SIZE=100
STALE_DELIVERING_SECONDS=120
WORKER_CONCURRENCY=10
UNKNOWN_RETRY_ENABLED=true
UNKNOWN_RETRY_BACKOFF_BASE_MS=5000

INBOUND_STANDARD_SECRET=base64:replace_with_32_or_more_random_bytes_base64
INBOUND_GITHUB_SECRET=replace_with_github_webhook_secret
INBOUND_STRIPE_SECRET=whsec_replace_with_stripe_secret
INBOUND_SLACK_SECRET=replace_with_slack_signing_secret
INBOUND_TELEGRAM_SECRET=replace_with_telegram_secret_token
INBOUND_GENERIC_SECRET=replace_with_generic_secret

OUTBOUND_APP_SECRET=base64:replace_with_32_or_more_random_bytes_base64
OUTBOUND_TGSERVER_SECRET=base64:replace_with_32_or_more_random_bytes_base64

DEST_APP_URL=http://example-app:3000/internal/webhooks
DEST_TGSERVER_URL=http://tgserver:7374/internal/webhooks
