{
  "name": "gace-webhook-gateway",
  "version": "1.2.2",
  "private": true,
  "description": "Independent universal inbound webhook gateway with signature verification, durable ledger, queue delivery, retries, replay, audit, metrics, and emergency spool recovery.",
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "audit:high": "npm audit --audit-level=high",
    "secret": "tsx src/generate-secret.ts"
  },
  "dependencies": {
    "bullmq": "5.80.4",
    "dotenv": "16.6.1",
    "express": "4.22.2",
    "helmet": "8.1.0",
    "ioredis": "5.6.1",
    "pg": "8.16.3",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "@types/express": "4.17.23",
    "@types/node": "22.15.31",
    "@types/pg": "8.15.4",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vitest": "3.2.7"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
