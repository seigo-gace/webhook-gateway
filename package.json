{
  "name": "gace-webhook-gateway",
  "version": "1.1.1",
  "private": true,
  "description": "Independent universal webhook gateway with signature verification, durable ledger, queue, retries, replay, audit, metrics and emergency spool recovery.",
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "secret": "tsx src/generate-secret.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.7.10",
    "@bull-board/express": "^6.7.10",
    "bullmq": "^5.56.4",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "prom-client": "^15.1.3",
    "undici": "^7.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^22.15.31",
    "@types/pg": "^8.15.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
